APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack          # Use 'json' for structured logging in production
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum
SANCTUM_TOKEN_EXPIRY_MINUTES=    # Leave empty for non-expiring tokens

# Hostinger API
HOSTINGER_API_BASE_URL=https://developers.hostinger.com
HOSTINGER_API_TOKEN=
HOSTINGER_API_TIMEOUT_SECONDS=10

# Hostinger cache TTLs (seconds)
HOSTINGER_CACHE_TTL_VPS_LIST=86400
HOSTINGER_CACHE_TTL_OS_TEMPLATES=86400
HOSTINGER_CACHE_TTL_DATACENTERS=86400
HOSTINGER_CACHE_TTL_DOMAIN_AVAILABILITY=3600

# Hostinger API quota controls (calls per day)
HOSTINGER_API_QUOTA_WARN_AT=800
# HOSTINGER_API_QUOTA_HARD_LIMIT=   # Disabled by default (warn-only); set a value to enforce 503

# Observability
SLOW_REQUEST_THRESHOLD_MS=2000

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=365
AUTH_LOG_RETENTION_DAYS=365
DRIFT_REPORT_RETENTION_DAYS=90
ACCESS_REVIEW_RETENTION_DAYS=730
FAILED_JOB_RETENTION_DAYS=30
